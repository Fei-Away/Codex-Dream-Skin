{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Fei-Away/Codex-Dream-Skin/schemas/dreamskin-manifest.schema.json",
  "title": "Dream Skin v1 packaged manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "packageId",
    "packageVersion",
    "name",
    "author",
    "targets",
    "minimumDreamSkinVersion",
    "resources",
    "contentHash"
  ],
  "properties": {
    "formatVersion": { "const": 1 },
    "packageId": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
    },
    "packageVersion": { "$ref": "#/$defs/semver" },
    "name": { "$ref": "#/$defs/singleLine80" },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/singleLine80" },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://(?![^/?#]*@)",
          "maxLength": 2048
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "enum": ["macos", "windows"] }
    },
    "minimumDreamSkinVersion": { "$ref": "#/$defs/semver" },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["background"],
      "properties": {
        "background": { "$ref": "#/$defs/resource" },
        "preview": {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            { "properties": { "bytes": { "maximum": 4194304 } } }
          ]
        }
      }
    },
    "contentHash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "singleLine80": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u2028\\u2029]+$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mediaType", "bytes", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^assets/[a-z0-9][a-z0-9._-]*$", "maxLength": 180 },
        "mediaType": { "enum": ["image/png", "image/jpeg", "image/webp"] },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "oneOf": [
        { "properties": { "path": { "pattern": "\\.png$" }, "mediaType": { "const": "image/png" } } },
        { "properties": { "path": { "pattern": "\\.jpe?g$" }, "mediaType": { "const": "image/jpeg" } } },
        { "properties": { "path": { "pattern": "\\.webp$" }, "mediaType": { "const": "image/webp" } } }
      ]
    }
  }
}
