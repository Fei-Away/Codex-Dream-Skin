{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Dream Skin Manager",
  "version": "0.5.0",
  "identifier": "com.feiaway.codex-dream-skin-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Dream Skin Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 640,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "theme": "Dark",
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": ["acrylic"],
          "color": "#0a0d16d8"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/editor-preview/**/*",
          "$APPDATA/themes/**/*",
          "$APPDATA/builtin/**/*",
          "$APPDATA/platform-cache/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": [
      "../../windows",
      "../../macos"
    ]
  }
}
